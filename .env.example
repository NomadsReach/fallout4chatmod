# Copy to .env and fill in your values — never commit .env to git
BOT_SECRET=generate_a_random_string_here
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Moderation — who may run !ban / !unban / !bans in the relay channel.
# Comma-separated Discord user IDs (right-click user → Copy User ID, dev mode on).
ADMIN_IDS=
# Optional: a single role ID whose members may moderate.
ADMIN_ROLE_ID=

# Game UserIDs (hex64) exempt from the username filter — admins can use any name.
# Comma-separated. Find an id with !whois <name> in the relay channel.
ADMIN_USER_IDS=
