{
  "name": "falloutchat-ui",
  "version": "1.0.0",
  "description": "FalloutChat TypeScript UI - Modular architecture with Prisma patterns",
  "type": "module",
  "scripts": {
    "build": "esbuild main.ts --bundle --minify --target=es2020 --outfile=dist/chat-bundle.js --sourcemap",
    "build:dev": "esbuild main.ts --bundle --target=es2020 --outfile=dist/chat-bundle.js --sourcemap",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
